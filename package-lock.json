{
  "name": "cocofelon-v2",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run content:prep && npm run content:validate && astro build",
    "content:prep": "node scripts/content/transposer.js",
    "content:validate": "node scripts/content/validate-content.js",
    "deploy": "bash scripts/deploy/deploy.sh",
    "deploy:netlify": "node scripts/deploy/netlify-deploy.js",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src/**/*.{js,ts,astro}",
    "format": "prettier --write .",
    "clean": "rm -rf dist/ .astro/ node_modules/.cache/"
  },
  "dependencies": {
    "@astrojs/netlify": "^7.0.13",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.7",
    "autoprefixer": "^10.5.0",
    "decap-cms-app": "^3.14.1",
    "gsap": "^3.15.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "three": "^0.184.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}