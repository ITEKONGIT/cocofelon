---
import Layout from '../layouts/Layout.astro';
import PageShell from '../components/system/PageShell.astro';
import Badge from '../components/system/Badge.astro';
import ActionLink from '../components/system/ActionLink.astro';
import { ArrowUpRight, GitBranch, Mail } from '@lucide/astro';
import { projects } from '../data/projects';
---

<Layout>
  <PageShell class="home-shell">
    <section class="hero" aria-labelledby="hero-title">
      <Badge tone="accent">Emmanuel Awe / COCOFELON</Badge>
      <div class="wordmark" aria-label="COCOFELON">
        <span>COCO</span><span>FELON</span>
      </div>
      <h1 id="hero-title">I build software, then I ask where it breaks.</h1>
      <p class="hero-copy">
        I work across software engineering, offensive security, and fintech systems. I build the tools I need,
        study the assumptions inside other people's systems, and write about what survives contact with reality.
      </p>
      <p class="hero-context">
        The names matter to me. Jericho, Beulah, ShellVault. They come from the same place as the work: faith,
        questions about power and trust, and a habit of looking closely at what people call finished.
      </p>
      <div class="hero-actions">
        <ActionLink href="/projects" variant="primary">View my projects</ActionLink>
        <ActionLink href="/about">Read my story</ActionLink>
      </div>
    </section>

    <section class="work" aria-labelledby="work-title">
      <div class="section-heading">
        <div>
          <p class="eyebrow">My repositories</p>
          <h2 id="work-title">The work I actually claim.</h2>
        </div>
        <a class="text-link" href="https://github.com/ITEKONGIT" target="_blank" rel="noopener">
          GitHub <GitBranch size={15} stroke-width={1.8} aria-hidden="true" />
        </a>
      </div>
      <div class="project-list">
        {projects.map((project, index) => (
          <a class="project-row" href={project.href} target="_blank" rel="noopener">
            <span class="project-index">0{index + 1}</span>
            <span class="project-main">
              <span class="project-name">{project.name}</span>
              <span class="project-description">{project.description}</span>
              <span class="project-note">{project.note}</span>
            </span>
            <span class="project-meta">
              <span>{project.language}</span>
              <ArrowUpRight size={16} stroke-width={1.8} aria-hidden="true" />
            </span>
          </a>
        ))}
      </div>
    </section>

    <section class="closing" aria-label="Contact">
      <div>
        <p class="eyebrow">The rest of the story</p>
        <h2>Security is one part of the work. Building is the other.</h2>
      </div>
      <a class="contact-link" href="mailto:hello@cocofelon.lol">
        <Mail size={17} stroke-width={1.8} aria-hidden="true" />
        hello@cocofelon.lol
      </a>
    </section>
  </PageShell>
</Layout>

<style>
  .home-shell { padding-bottom: 4rem; }
  .hero { max-width: 760px; padding: 1.5rem 0 4.5rem; }
  .wordmark { display: flex; flex-wrap: wrap; gap: 0.45em; margin: 1.6rem 0 1.1rem; font-family: 'Syne', sans-serif; font-size: clamp(2.8rem, 15vw, 7rem); font-weight: 800; line-height: 0.88; letter-spacing: 0; }
  .wordmark span:first-child { color: var(--text); }
  .wordmark span:last-child { color: transparent; -webkit-text-stroke: 1px var(--accent); }
  h1 { max-width: 680px; color: var(--text); font-size: clamp(2rem, 9vw, 4.8rem); line-height: 1.02; letter-spacing: 0; }
  .hero-copy, .hero-context { max-width: 650px; margin-top: 1rem; color: var(--text-muted); font-size: 0.96rem; font-weight: 300; line-height: 1.8; }
  .hero-context { color: var(--text); }
  .hero-actions { display: grid; gap: 0.7rem; margin-top: 1.4rem; }
  .work { border-top: 1px solid var(--border-muted); padding-top: 1.35rem; }
  .section-heading { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1.2rem; }
  .eyebrow { color: var(--accent); font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.15em; text-transform: uppercase; }
  h2 { margin-top: 0.55rem; color: var(--text); font-size: clamp(1.45rem, 6vw, 2.5rem); line-height: 1.1; letter-spacing: 0; }
  .text-link, .contact-link { display: inline-flex; align-items: center; gap: 0.45rem; color: var(--text-muted); font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; }
  .text-link:hover, .contact-link:hover { color: var(--accent-strong); }
  .project-list { border-top: 1px solid var(--border-muted); }
  .project-row { display: grid; grid-template-columns: 2rem 1fr auto; gap: 0.8rem; align-items: start; padding: 1rem 0; border-bottom: 1px solid var(--border-muted); transition: padding 0.2s ease, border-color 0.2s ease; }
  .project-row:hover { padding-left: 0.35rem; border-color: var(--accent-border); }
  .project-index, .project-meta { color: var(--text-faint); font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; }
  .project-main { display: flex; flex-direction: column; gap: 0.25rem; min-width: 0; }
  .project-name { color: var(--text); font-family: 'Syne', sans-serif; font-size: 1.05rem; font-weight: 700; }
  .project-description, .project-note { color: var(--text-muted); font-size: 0.78rem; line-height: 1.5; }
  .project-note { color: var(--text-faint); }
  .project-meta { display: flex; align-items: center; gap: 0.4rem; color: var(--accent); }
  .closing { display: grid; gap: 1.25rem; margin-top: 4.5rem; padding-top: 1.35rem; border-top: 1px solid var(--border-muted); }
  .contact-link { width: fit-content; color: var(--text); }
  @media (min-width: 560px) {
    .hero-actions { display: flex; flex-wrap: wrap; }
    .section-heading { flex-direction: row; align-items: end; justify-content: space-between; }
    .closing { grid-template-columns: 1fr auto; align-items: end; }
  }
  @media (min-width: 860px) {
    .hero { padding-top: 4rem; padding-bottom: 7rem; }
    .hero-copy, .hero-context { font-size: 1.03rem; }
    .project-row { grid-template-columns: 3rem 1fr auto; padding: 1.25rem 0; }
  }
</style>
