---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog', ({ data }) => data.status !== 'draft');

// Sort by date descending
const posts = allPosts.sort((a, b) => {
  return new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime();
});

const categoryOptions = [
  { key: 'all', label: 'All writing' },
  { key: 'security', label: 'Security' },
  { key: 'engineering', label: 'Engineering' },
  { key: 'fintech', label: 'Fintech' },
  { key: 'ai', label: 'AI + tooling' },
  { key: 'notes', label: 'Notes' },
];

const categoryLabels: Record<string, string> = {
  security: 'Security',
  engineering: 'Engineering',
  fintech: 'Fintech',
  ai: 'AI + tooling',
  notes: 'Notes',
};

const countFor = (category: string) => category === 'all'
  ? posts.length
  : posts.filter((post) => post.data.category === category).length;

// Standardize the archive date format to YYYY-MM-DD
const formatArchiveDate = (dateInput: any) => {
  if (!dateInput) return '—';
  const d = new Date(dateInput);
  if (isNaN(d.getTime())) return String(dateInput);
  return d.toISOString().split('T')[0];
};
---

<Layout>
  <div class="archive">
    <header class="archive-header">
      <p class="archive-tag">Emmanuel Awe / writing</p>
      <h1 class="archive-title">Notes from the work.</h1>
      <p class="archive-sub">Security, software, finance systems, and the lessons that only show up after building.</p>
    </header>

    <div class="archive-filters" id="filters" aria-label="Filter writing by category">
      {categoryOptions.map((category) => (
        <button class:list={['filter-btn', category.key === 'all' && 'active']} data-filter={category.key} type="button" aria-pressed={category.key === 'all'}>
          <span>{category.label}</span><small>{countFor(category.key)}</small>
        </button>
      ))}
    </div>

    <div class="archive-table" id="archive-table">
      {posts.map((post: any) => (
        <a
          href={`/blog/${post.data.slug}`}
          class="archive-row"
          data-category={[post.data.category, ...(post.data.tags || [])].join('|')}
        >
          <span class="row-date">{formatArchiveDate(post.data.date)}</span>
          <span class="row-title">{post.data.title}</span>
          <span class="row-tags">
            {[categoryLabels[post.data.category], ...(post.data.tags || [])].join(' · ')}
          </span>
          <span class="row-arrow">→</span>
        </a>
      ))}
    </div>

    <div class="archive-empty" id="archive-empty" style="display:none;">
      <p>No transmissions match this filter.</p>
    </div>
  </div>
</Layout>

<style>
  .archive {
    min-height: 100vh;
    max-width: 980px;
    margin: 0 auto;
    padding: 5.25rem 0.75rem 4rem;
    position: relative;
    z-index: 10;
  }

  .archive-header {
    margin-bottom: 2.5rem;
  }

  .archive-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--cyan);
    margin-bottom: 1rem;
  }

  .archive-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.3rem, 10vw, 5rem);
    font-weight: 800;
    letter-spacing: 0;
    margin-bottom: 0.5rem;
    color: var(--stardust);
  }

  .archive-sub {
    font-family: 'Lexend', sans-serif;
    font-size: 0.95rem;
    color: var(--ash);
    font-weight: 300;
    max-width: 620px;
  }

  /* Filters */
  .archive-filters {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
    padding: 0.8rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    min-height: 2.35rem;
    padding: 0.55rem 0.75rem;
    background: transparent;
    border: 1px solid var(--border-muted);
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .filter-btn.active,
  .filter-btn:hover {
    border-color: var(--accent-border);
    color: var(--accent-strong);
    background: var(--accent-soft);
  }

  .filter-btn small { color: var(--text-faint); font-size: 0.55rem; letter-spacing: 0; }
  .filter-btn.active small, .filter-btn:hover small { color: var(--accent-strong); }

  /* Table */
  .archive-table {
    display: flex;
    flex-direction: column;
  }

  .archive-row {
    display: grid;
    grid-template-columns: 110px minmax(0, 1fr) 200px 30px;
    align-items: center;
    gap: 1rem;
    padding: 1.15rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    text-decoration: none;
    transition: background 0.3s ease, border-color 0.3s ease, opacity 0.3s ease;
  }

  .archive-row:hover {
    background: rgba(0, 240, 255, 0.015);
    border-bottom-color: rgba(0, 240, 255, 0.1);
  }

  .row-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: var(--accent);
    letter-spacing: 0.08em;
    opacity: 0.7;
  }

  .row-title {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    transition: color 0.3s ease;
    letter-spacing: -0.01em;
  }

  .archive-row:hover .row-title {
    color: var(--cyan);
  }

  .row-tags {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.55rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    opacity: 0.5;
  }

  .row-arrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-faint);
    text-align: right;
    transition: all 0.3s ease;
  }

  .archive-row:hover .row-arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  .archive-empty {
    text-align: center;
    padding: 4rem 2rem;
    font-family: 'Lexend', sans-serif;
    color: var(--ash);
    font-style: italic;
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .archive {
      padding: 5.25rem 0.75rem 3rem;
    }

    .archive-row {
      grid-template-columns: 1fr;
      gap: 0.2rem;
      padding: 1rem 0;
    }

    .row-tags {
      display: none;
    }

    .row-arrow {
      display: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  // Filter animation
  const filterButtons = document.querySelectorAll('.filter-btn');
  const rows = document.querySelectorAll('.archive-row');
  const empty = document.getElementById('archive-empty');

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;

      filterButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filterButtons.forEach((button) => button.setAttribute('aria-pressed', String(button === btn)));

      let visibleCount = 0;

      rows.forEach(row => {
        const categories = (row as HTMLElement).dataset.category || '';
        const isMatch = filter === 'all' || categories.split('|').includes(filter || '');

        if (isMatch) {
          visibleCount++;
          gsap.to(row, {
            opacity: 1,
            height: 'auto',
            duration: 0.35,
            ease: 'power2.out',
            onStart: () => { (row as HTMLElement).style.display = 'grid'; }
          });
        } else {
          gsap.to(row, {
            opacity: 0,
            height: 0,
            paddingTop: 0,
            paddingBottom: 0,
            borderBottomWidth: 0,
            duration: 0.25,
            ease: 'power2.in',
            onComplete: () => { (row as HTMLElement).style.display = 'none'; }
          });
        }
      });

      // Show/hide empty state
      if (visibleCount === 0 && empty) {
        gsap.to(empty, { opacity: 1, display: 'block', duration: 0.3 });
      } else if (empty) {
        gsap.to(empty, { opacity: 0, display: 'none', duration: 0.2 });
      }
    });
  });

  // Initial reveal animation
  gsap.fromTo('.archive-header',
    { opacity: 0, y: 20 },
    { opacity: 1, y: 0, duration: 1, ease: 'expo.out', delay: 0.2 }
  );

  gsap.fromTo('.archive-row',
    { opacity: 0, y: 10 },
    { opacity: 1, y: 0, duration: 0.5, stagger: 0.04, ease: 'expo.out', delay: 0.5 }
  );
</script>
