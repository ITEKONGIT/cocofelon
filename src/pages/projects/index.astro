---
import Layout from '../../layouts/Layout.astro';
import PageShell from '../../components/system/PageShell.astro';
import { ArrowUpRight, GitBranch } from '@lucide/astro';
import { projects } from '../../data/projects';
---

<Layout>
  <PageShell class="projects-shell">
    <header class="page-header">
      <p class="eyebrow">ITEKONGIT / projects</p>
      <h1>Projects I built and keep close.</h1>
      <p class="intro">No filler catalogue. These are the repositories I want attached to my name right now.</p>
      <a class="github-link" href="https://github.com/ITEKONGIT" target="_blank" rel="noopener">
        <GitBranch size={17} stroke-width={1.8} aria-hidden="true" />
        Open GitHub profile
        <ArrowUpRight size={15} stroke-width={1.8} aria-hidden="true" />
      </a>
    </header>

    <div class="project-list">
      {projects.map((project, index) => (
        <a class="project-row" href={project.href} target="_blank" rel="noopener">
          <span class="project-index">0{index + 1}</span>
          <span class="project-main">
            <span class="project-name">{project.name}</span>
            <span class="project-description">{project.description}</span>
            <span class="project-note">{project.note}</span>
          </span>
          <span class="project-meta">{project.language}<ArrowUpRight size={17} stroke-width={1.8} aria-hidden="true" /></span>
        </a>
      ))}
    </div>
  </PageShell>
</Layout>

<style>
  .projects-shell { max-width: 900px; }
  .page-header { max-width: 690px; padding: 1.5rem 0 3.5rem; }
  .eyebrow { color: var(--accent); font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.15em; text-transform: uppercase; }
  h1 { margin-top: 0.8rem; color: var(--text); font-size: clamp(2.25rem, 10vw, 5rem); line-height: 1; letter-spacing: 0; }
  .intro { max-width: 560px; margin-top: 1rem; color: var(--text-muted); font-size: 0.98rem; font-weight: 300; line-height: 1.8; }
  .github-link { display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 1.4rem; color: var(--text); font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; }
  .github-link:hover { color: var(--accent-strong); }
  .project-list { border-top: 1px solid var(--border-muted); }
  .project-row { display: grid; grid-template-columns: 2rem 1fr auto; gap: 0.8rem; align-items: start; padding: 1.05rem 0; border-bottom: 1px solid var(--border-muted); transition: padding 0.2s ease, border-color 0.2s ease; }
  .project-row:hover { padding-left: 0.35rem; border-color: var(--accent-border); }
  .project-index, .project-meta { color: var(--text-faint); font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; }
  .project-main { display: flex; flex-direction: column; gap: 0.25rem; min-width: 0; }
  .project-name { color: var(--text); font-family: 'Syne', sans-serif; font-size: 1.1rem; font-weight: 700; }
  .project-description, .project-note { color: var(--text-muted); font-size: 0.8rem; line-height: 1.5; }
  .project-note { color: var(--text-faint); }
  .project-meta { display: flex; align-items: center; gap: 0.45rem; color: var(--accent); }
  @media (min-width: 860px) { .page-header { padding-top: 4rem; padding-bottom: 5rem; } .project-row { grid-template-columns: 3rem 1fr auto; padding: 1.3rem 0; } }
</style>
